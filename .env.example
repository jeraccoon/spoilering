# Copia este archivo como .env cuando prepares el proyecto en local.

# Base de datos PostgreSQL.
# Ejemplo local:
# DATABASE_URL="postgresql://usuario:password@localhost:5432/spoilering?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/spoilering?schema=public"

# URL publica de la web. En local puedes dejar esta.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# OpenAI. Esta clave solo debe estar en .env, nunca en el navegador.
OPENAI_API_KEY=""

# Modelo usado por el generador interno. Puedes cambiarlo si quieres controlar coste/calidad.
OPENAI_MODEL="gpt-4o-mini"

# TMDb. Se usa en /admin/generar para buscar peliculas y series reales antes
# de generar una ficha con IA.
TMDB_API_KEY=""

# Protección simple para rutas /admin y /api/admin.
# Si las dejas vacías en local, no se pedirá usuario/contraseña.
ADMIN_USERNAME=""
ADMIN_PASSWORD=""
